# Inkvoice PWA — Hostinger/LiteSpeed.
# The web app manifest is now manifest.json (an extension the server serves natively
# as application/json, which browsers accept), so the home-screen icon no longer
# depends on this file surviving a deploy. This block is a belt-and-suspenders that
# forces the correct manifest MIME type even if the server default ever changes.
<Files "manifest.json">
  ForceType application/manifest+json
</Files>
<Files "manifest.webmanifest">
  ForceType application/manifest+json
</Files>
# Always revalidate the manifest so a fixed one is never masked by a stale cache.
<IfModule mod_headers.c>
  <FilesMatch "manifest\.(json|webmanifest)$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
  # Icons + favicon: always revalidate too. The server's default was caching these
  # for days, so after a redeploy the browser kept serving a stale/blank icon under
  # the same filename and the home-screen icon "broke again". Revalidating (cheap
  # 304 when unchanged) means a corrected icon is picked up immediately — no need to
  # rename the icon files on every release.
  <FilesMatch "\.(png|ico)$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>
